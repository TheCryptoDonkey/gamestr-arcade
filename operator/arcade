#!/usr/bin/env bash
# Gamestr Arcade - simple control helper for the booth operator.
#
#   arcade start     # start the arcade (if it isn't already running)
#   arcade stop      # stop it (returns to the desktop)
#   arcade restart   # stop + start cleanly
#   arcade status    # is it running? when did it start?
#   arcade logs      # live log stream (Ctrl+C to stop watching)
#
# The arcade also starts on its own every time the machine boots - you only
# need these if you've quit it (Ctrl+Q) or want to restart it.

set -euo pipefail
unit=gamestr-arcade

case "${1:-}" in
  start)   systemctl --user start   "$unit" && echo "▶ Arcade starting…" ;;
  stop)    systemctl --user stop    "$unit" && echo "■ Arcade stopped - you're back at the desktop." ;;
  restart) systemctl --user restart "$unit" && echo "↻ Arcade restarting…" ;;
  status)  systemctl --user status  "$unit" --no-pager ;;
  logs)    journalctl --user -u "$unit" -f ;;
  *)
    echo "Gamestr Arcade control"
    echo "usage: arcade {start|stop|restart|status|logs}"
    ;;
esac
